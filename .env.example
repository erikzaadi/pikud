# ── Required ──────────────────────────────────────────────────────────────────

# City to monitor - must match exactly what the Pikud HaOref API returns (Hebrew)
# Default: תל אביב (Tel Aviv)
CITY="תל אביב"

# ── Optional: remote access (deploy.sh / logs.sh) ─────────────────────────────

# Hostname or IP of your Raspberry Pi
PI_HOST="shelterpie.local"
# SSH user on the Pi (default: pi)
PI_USER="pi"

# ── Optional: Particle Photon integration ─────────────────────────────────────

# Leave blank to disable - alerts.py will run fine without these
PARTICLE_DEVICE_ID=""
PARTICLE_ACCESS_TOKEN=""    # particle token create
